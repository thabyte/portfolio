---
import '@fontsource-variable/inter';
import '@fontsource-variable/jetbrains-mono';
import '../styles/global.css';
import ThemeToggle from '../components/ThemeToggle.tsx';

interface Props {
  title?: string;
  description?: string;
  /** Path-only, e.g. "/work/zed-pos". Used for canonical + OG url. */
  path?: string;
}

const {
  title = 'Titus Muthomi — Senior Software Engineer',
  description = 'Senior software engineer building fintech and payments infrastructure across East Africa. Distributed systems on the JVM, Go, and Rust, with production ML and RAG.',
  path = '/',
} = Astro.props;

const canonical = new URL(path, Astro.site ?? 'https://kalunge.io').toString();
const ogImage = new URL('/og/default.png', Astro.site ?? 'https://kalunge.io').toString();

const nav = [
  { href: '/#work', label: 'Work' },
  { href: '/about', label: 'About' },
  { href: '/#contact', label: 'Contact' },
];

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Titus Muthomi',
  jobTitle: 'Senior Software Engineer',
  url: 'https://kalunge.io',
  email: 'mailto:muthomititus@gmail.com',
  address: { '@type': 'PostalAddress', addressLocality: 'Nairobi', addressCountry: 'KE' },
  sameAs: ['https://www.linkedin.com/in/kalunge/', 'https://github.com/Kalunge'],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="canonical" href={canonical} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Apply theme before paint to avoid flash -->
    <script is:inline>
      const t = localStorage.getItem('theme');
      if (t === 'dark' || (!t && matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      }
    </script>

    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
  </head>

  <body class="min-h-screen antialiased">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-[var(--color-ink)] focus:px-4 focus:py-2 focus:text-[var(--color-paper)]"
      >Skip to content</a
    >

    <header
      class="sticky top-0 z-40 border-b border-[var(--color-line)] bg-[var(--color-paper)]/80 backdrop-blur"
    >
      <nav class="mx-auto flex max-w-3xl items-center justify-between px-6 py-4">
        <a href="/" class="font-mono text-sm font-medium tracking-tight" aria-label="Home">
          kalunge<span class="text-[var(--color-accent)]">.io</span>
        </a>
        <div class="flex items-center gap-5">
          {
            nav.map((item) => (
              <a
                href={item.href}
                class="text-sm text-[var(--color-ink-mute)] transition-colors hover:text-[var(--color-ink)]"
              >
                {item.label}
              </a>
            ))
          }
          <ThemeToggle client:load />
        </div>
      </nav>
    </header>

    <main id="main">
      <slot />
    </main>

    <footer class="mt-24 border-t border-[var(--color-line)]">
      <div
        class="mx-auto flex max-w-3xl flex-col items-start justify-between gap-3 px-6 py-8 text-sm text-[var(--color-ink-mute)] sm:flex-row sm:items-center"
      >
        <span>© {new Date().getFullYear()} Titus Muthomi · Nairobi, Kenya</span>
        <span class="font-mono text-xs">Built with Astro</span>
      </div>
    </footer>

    <!-- Reveal-on-scroll -->
    <script is:inline>
      const obs = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              e.target.classList.add('is-visible');
              obs.unobserve(e.target);
            }
          }
        },
        { rootMargin: '0px 0px -10% 0px' }
      );
      document.querySelectorAll('.reveal').forEach((el) => obs.observe(el));
    </script>
  </body>
</html>
