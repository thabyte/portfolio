---
import Base from '../layouts/Base.astro';
---

<Base title="Not found — Titus Muthomi" path="/404">
  <section class="mx-auto flex max-w-3xl flex-col items-start px-6 py-32">
    <p class="font-mono text-sm text-[var(--color-accent)]">404</p>
    <h1 class="mt-3 text-3xl font-semibold tracking-tight">This page doesn't exist.</h1>
    <p class="mt-3 text-[var(--color-ink-soft)]">The link may be broken, or the page moved.</p>
    <a
      href="/"
      class="mt-6 rounded-md bg-[var(--color-ink)] px-5 py-2.5 text-sm font-medium text-[var(--color-paper)] transition-opacity hover:opacity-90"
      >Back home</a
    >
  </section>
</Base>
