---
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import Base from '../../layouts/Base.astro';
import BackLink from '../../components/BackLink.astro';

export const getStaticPaths = (async () => {
  const items = await getCollection('work');
  return items.map((item) => ({ params: { slug: item.id }, props: { item } }));
}) satisfies GetStaticPaths;

const { item } = Astro.props;
const { Content } = await render(item);
const d = item.data;
---

<Base title={`${d.title} — Titus Muthomi`} description={d.summary} path={`/work/${item.id}`}>
  <article class="mx-auto max-w-3xl px-6 pb-12 pt-16">
    <BackLink href="/#work" label="All work" />

    <header class="mt-8 border-b border-[var(--color-line)] pb-8">
      {
        d.client && (
          <p class="font-mono text-xs uppercase tracking-wider text-[var(--color-ink-mute)]">
            {d.client}
          </p>
        )
      }
      <h1 class="mt-2 text-3xl font-semibold tracking-tight sm:text-4xl">{d.title}</h1>
      <p class="mt-3 text-lg text-[var(--color-ink-soft)]">{d.tagline}</p>

      <ul class="mt-5 flex flex-wrap gap-2">
        {
          d.tags.map((t) => (
            <li class="rounded-full bg-[var(--color-paper-soft)] px-2.5 py-1 font-mono text-[11px] text-[var(--color-ink-mute)]">
              {t}
            </li>
          ))
        }
      </ul>

      {
        (d.liveUrl || d.repoUrl) && (
          <div class="mt-6 flex flex-wrap gap-3">
            {d.liveUrl && (
              <a
                href={d.liveUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="rounded-md bg-[var(--color-ink)] px-4 py-2 text-sm font-medium text-[var(--color-paper)] transition-opacity hover:opacity-90"
              >
                Live demo ↗
              </a>
            )}
            {d.repoUrl && (
              <a
                href={d.repoUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="rounded-md border border-[var(--color-line)] px-4 py-2 text-sm font-medium transition-colors hover:border-[var(--color-accent)] hover:text-[var(--color-accent)]"
              >
                GitHub ↗
              </a>
            )}
          </div>
        )
      }
      {
        !d.isPublic && (
          <p class="mt-6 rounded-md border border-[var(--color-line)] bg-[var(--color-paper-soft)] px-4 py-3 text-sm text-[var(--color-ink-mute)]">
            Client work — code is private. Architecture walk-through available on request.
          </p>
        )
      }
    </header>

    <div class="prose mt-10 max-w-none">
      <Content />
    </div>

    <div class="mt-12 border-t border-[var(--color-line)] pt-6">
      <p class="font-mono text-xs uppercase tracking-wider text-[var(--color-ink-mute)]">Stack</p>
      <p class="mt-2 font-mono text-sm text-[var(--color-ink-soft)]">{d.stack}</p>
    </div>
  </article>
</Base>
