---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import ProjectCard from '../components/ProjectCard.astro';
import ContactForm from '../components/ContactForm.tsx';

const work = (await getCollection('work'))
  .filter((w) => w.data.featured)
  .sort((a, b) => a.data.order - b.data.order);

const skills = [
  { label: 'Languages', items: 'Java · Kotlin · Go · Rust · Python · TypeScript' },
  { label: 'Backend', items: 'Spring Boot · FastAPI · Chi (Go) · Tauri (Rust) · gRPC · REST' },
  { label: 'Data & messaging', items: 'PostgreSQL · MySQL · Redis · Elasticsearch · Kafka · Temporal' },
  { label: 'AI / ML', items: 'LangChain · ChromaDB · scikit-learn · LightGBM · PyTorch' },
  { label: 'Cloud & ops', items: 'AWS · Docker · GitHub Actions · Flyway · Caddy / Nginx' },
];
---

<Base>
  <!-- Hero -->
  <section class="mx-auto max-w-3xl px-6 pb-16 pt-20 sm:pt-28">
    <p class="font-mono text-sm text-[var(--color-accent)]">Senior Software Engineer</p>
    <h1 class="mt-4 text-4xl font-semibold leading-[1.1] tracking-tight sm:text-5xl">
      I build the backend systems that move money across Africa.
    </h1>
    <p class="mt-6 max-w-2xl text-lg leading-relaxed text-[var(--color-ink-soft)]">
      Multi-tenant banking platforms, payment switches, and point-of-sale
      infrastructure on the JVM, Go, and Rust — with production ML and RAG
      brought into the same products.
    </p>
    <div class="mt-8 flex flex-wrap items-center gap-3">
      <a
        href="#work"
        class="rounded-md bg-[var(--color-ink)] px-5 py-2.5 text-sm font-medium text-[var(--color-paper)] transition-opacity hover:opacity-90"
        >View work</a
      >
      <a
        href="#contact"
        class="rounded-md border border-[var(--color-line)] px-5 py-2.5 text-sm font-medium transition-colors hover:border-[var(--color-accent)] hover:text-[var(--color-accent)]"
        >Get in touch</a
      >
      <a
        href="/resume"
        class="px-3 py-2.5 text-sm font-medium text-[var(--color-ink-mute)] underline-offset-4 hover:text-[var(--color-ink)] hover:underline"
        >Résumé</a
      >
    </div>
    <p class="mt-8 font-mono text-xs text-[var(--color-ink-mute)]">
      Currently building banking infrastructure used across 5+ African markets.
    </p>
  </section>

  <!-- About teaser -->
  <section class="mx-auto max-w-3xl px-6 py-10">
    <div class="reveal space-y-4 text-[var(--color-ink-soft)]">
      <p class="leading-relaxed">
        I'm a software engineer in Nairobi with four years building fintech and
        e-commerce systems that serve millions of users. My day-to-day is
        distributed systems on the JVM, designed for the correctness,
        auditability, and resilience that money movement demands.
      </p>
      <a
        href="/about"
        class="inline-flex items-center gap-1 text-sm font-medium text-[var(--color-accent)]"
        >More about me
        <span aria-hidden="true">→</span></a
      >
    </div>
  </section>

  <!-- Work -->
  <section id="work" class="mx-auto max-w-3xl scroll-mt-20 px-6 py-10">
    <h2 class="font-mono text-sm uppercase tracking-wider text-[var(--color-ink-mute)]">
      Selected work
    </h2>
    <div class="mt-6 grid gap-5 sm:grid-cols-2">
      {
        work.map((w) => (
          <ProjectCard
            slug={w.id}
            title={w.data.title}
            summary={w.data.summary}
            tags={w.data.tags}
            client={w.data.client}
            isPublic={w.data.isPublic}
          />
        ))
      }
    </div>
  </section>

  <!-- Skills -->
  <section class="mx-auto max-w-3xl px-6 py-10">
    <h2 class="font-mono text-sm uppercase tracking-wider text-[var(--color-ink-mute)]">
      Tools I reach for
    </h2>
    <dl class="reveal mt-6 divide-y divide-[var(--color-line)]">
      {
        skills.map((s) => (
          <div class="flex flex-col gap-1 py-3 sm:flex-row sm:gap-6">
            <dt class="w-40 shrink-0 text-sm font-medium">{s.label}</dt>
            <dd class="font-mono text-sm text-[var(--color-ink-mute)]">{s.items}</dd>
          </div>
        ))
      }
    </dl>
  </section>

  <!-- Contact -->
  <section id="contact" class="mx-auto max-w-3xl scroll-mt-20 px-6 py-10">
    <h2 class="text-2xl font-semibold tracking-tight">Let's talk</h2>
    <p class="mt-3 max-w-xl text-[var(--color-ink-soft)]">
      I'm open to senior backend and fintech roles, and to contract work through
      vetted platforms. Email is fastest, or use the form.
    </p>
    <div class="mt-6 flex flex-wrap gap-4 text-sm">
      <a class="font-medium text-[var(--color-accent)]" href="mailto:muthomititus@gmail.com"
        >muthomititus@gmail.com</a
      >
      <a class="text-[var(--color-ink-mute)] hover:text-[var(--color-ink)]" href="https://www.linkedin.com/in/kalunge/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
      <a class="text-[var(--color-ink-mute)] hover:text-[var(--color-ink)]" href="https://github.com/Kalunge" target="_blank" rel="noopener noreferrer">GitHub</a>
    </div>
    <div class="mt-8 max-w-xl">
      <ContactForm client:visible />
    </div>
  </section>
</Base>
